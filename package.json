{
  "name": "xikipedia",
  "version": "1.0.0",
  "description": "Wikipedia as a social media feed - recreation of xikipedia.org by rebane2001",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "generate-data": "node scripts/generate-data.mjs",
    "generate-chunked-data": "node scripts/generate-chunked-data.mjs",
    "generate-test-data": "node scripts/generate-chunked-data.mjs --test"
  },
  "keywords": [
    "wikipedia",
    "social-media",
    "algorithm",
    "cloudflare-workers"
  ],
  "author": "rebane2001 (original), emily-flambe (deployment)",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.76.0"
  }
}
